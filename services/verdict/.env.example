# Verdict service — secrets loaded only from env (see src/verdict/config.py).
# Copy to .env (gitignored) and fill in. Never commit real keys.

# OpenAlex — a contact email enables the polite pool (no key required).
OPENALEX_MAILTO=you@example.com

# Semantic Scholar — optional key for higher rate limits + SPECTER2 embeddings.
S2_API_KEY=your_s2_key_here

# OpenRouter — single key fans out to cross-family :free models.
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model picks — cross-family :free models (ADR 0004), JSON-array member list; IDs churn, so these are illustrative — verify at:
# https://openrouter.ai/models
OPENROUTER_CHEAP_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_MEMBER_MODELS='[
  "deepseek/deepseek-chat-v3-0324:free",
  "qwen/qwen3-235b-a22b:free",
  "meta-llama/llama-3.3-70b-instruct:free",
  "google/gemma-3-27b-it:free"
]'
OPENROUTER_CHAIRMAN_MODEL=mistralai/mistral-small-3.2-24b-instruct:free
