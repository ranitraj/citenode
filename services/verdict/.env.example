# Verdict service — secrets loaded only from env (see src/verdict/config.py).
# Copy to .env (gitignored) and fill in. Never commit real keys.

# OpenAlex API Key
OPENALEX_API_KEY=your_openalex_key_here

# OpenRouter — single key fans out to cross-family :free models.
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model picks — cross-family :free models (ADR 0004), JSON-array member list; IDs churn, so these are illustrative — verify at:
# https://openrouter.ai/models
OPENROUTER_CHEAP_MODEL=openrouter/free

OPENROUTER_MEMBER_MODELS='[
  "openrouter/owl-alpha",
  "openai/gpt-oss-120b:free",
  "nvidia/nemotron-3-super-120b-a12b:free",
  "google/gemma-4-31b-it:free",
  "cohere/north-mini-code:free"
]'

OPENROUTER_CHAIRMAN_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free