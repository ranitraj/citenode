# https://editorconfig.org
# Universal editor config so non-VSCode IDEs (vim, IntelliJ, Sublime, etc.) match
# the ruff line-length and indentation settings from pyproject.toml.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 119

[*.{md,yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
